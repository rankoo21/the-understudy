# The Understudy environment
# The console runs fully in mock mode with no configuration.
# To switch to a deployed GenLayer contract, set the values below.

# "mock" (default) or "contract"
NEXT_PUBLIC_UNDERSTUDY_MODE=mock

# Deployed UnderstudyContract address (only used when mode is "contract")
NEXT_PUBLIC_UNDERSTUDY_CONTRACT=

# studionet (default) | bradbury | localnet
NEXT_PUBLIC_UNDERSTUDY_NETWORK=studionet
