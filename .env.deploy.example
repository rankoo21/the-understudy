# Copy this file to ".env.deploy" and paste your funded private key.
# ".env.deploy" is gitignored and must never be committed.
#
#   copy .env.deploy.example .env.deploy
#
# Private key of the account that deploys the contract. Hex, 0x optional.
GENLAYER_PRIVATE_KEY=

# studionet (default) | bradbury | localnet
GENLAYER_NETWORK=bradbury
